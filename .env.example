# Local SQLite (optional — default is data/atomquest.db in project root)
# Use a path relative to the project root, or omit this line entirely:
# DATABASE_URL=data/atomquest.db

# Production on Vercel (Turso — https://turso.tech)
# DATABASE_URL=libsql://your-database.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

JWT_SECRET=change-me-to-a-long-random-string
SESSION_SECRET=

PORT=8080
NODE_ENV=development
LOG_LEVEL=info
BASE_PATH=/

# VITE_API_URL=https://your-app.vercel.app
